{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://mhel14.github.io/web3-book-marketplace/",
  "engines": {
    "node": ">=20.19.5"
  },
  "scripts": {
    "check:node": "node -e \"const [major, minor, patch] = process.versions.node.split('.').map(Number); const ok = major > 20 || (major === 20 && (minor > 19 || (minor === 19 && patch >= 5))); if (!ok) { console.error('Node 20.19.5+ is required for the frontend. Run nvm use.'); process.exit(1); }\"",
    "dev": "vite",
    "build": "npm run check:node && tsc -b && vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "lint": "npm run check:node && eslint .",
    "test": "npm run check:node && vitest run",
    "test:watch": "npm run check:node && vitest",
    "preview": "npm run check:node && vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "ethers": "^6.16.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  }
}
